+int get_config_value(const char *filepath, const char *key, char *out) {
+    FILE *file = fopen(filepath, "r");
+    if (!file)
+        return 0;
+    
+    size_t line_buf_size = (strcmp(key, "text") == 0) ? 4000 : 30;
+
+    char *line = malloc(line_buf_size);
+
+    if (!line) {
+        fclose(file);
+        return 0;
+    }
+
+    size_t keyLen = strlen(key);
+
+    while (fgets(line, (int)line_buf_size, file)) {
+          if (strncmp(line, key, keyLen) == 0){            
+            char *value = line + keyLen + 1;
+
+            char *newline = strchr(value, ';');
+            if (newline) *newline = '\0';
+
+            strcpy(out, value);
+            for (char *p = out; *p; p++) {
+              if (*p == '|') *p = '\n';
+            }
+            fclose(file);
+            free(line);
+            return 1; 
+          }
+
+    }
+    fclose(file);
+    free(line);
+    return 0;
+}
