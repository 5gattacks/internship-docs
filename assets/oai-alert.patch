+
+int build_sib8_segments(nr_SIBs_t **out_segments,
+                        int *out_num_segments)
+{
+  *out_segments    = NULL;
+  *out_num_segments = 0;
+
+  char hex_str[5]; 
+  const char *config_file = "../../../sib8.conf";
+  
+  char alert_buffer[4000] = {0};
+  get_config_value(config_file, "text", alert_buffer);
+
+  uint8_t *dcs = CALLOC(1, 1);
+  get_config_value(config_file, "dataCodingScheme", hex_str);
+  hex2bytes(hex_str, dcs, 1);
+
+  char mode[5];
+  get_config_value(config_file, "mode", mode);
+ 
+
+  const int MAX_SEGMENTS = 32;
+  
+  uint8_t *encoded = NULL;
+  int text_len = 0;
+  size_t total_octets = 0;
+
+  size_t num_segments = 0;
+
+  if (*dcs == 0x01) {
+
+    text_len = strlen(alert_buffer);
+    num_segments = (text_len + 93 - 1) / 93;
+
+  } else if (*dcs == 0x48) {
+
+    size_t max_bytes = 82 * MAX_SEGMENTS;
+    encoded = malloc(max_bytes);
+
+    total_octets = utf8_to_ucs2(alert_buffer, encoded, max_bytes);
+    num_segments = (total_octets + 82 -1) / 82;
+    
+  } 
+       
+  
+
+  if (num_segments > MAX_SEGMENTS)
+    num_segments = MAX_SEGMENTS;
+
+  nr_SIBs_t *segments = calloc(num_segments, sizeof(*segments));
+
+  for (int seg_no = 0; seg_no < num_segments; seg_no++) {
+
+    NR_SIB8_t *sib8 = calloc(1, sizeof(*sib8));
+    AssertFatal(sib8, "SIB8: out of memory\n");
+    uint8_t* segment;
+    int i = 0;
+
+    if(mode[0] == '0'){
+
+      if(seg_no == 0){
+          sib8->dataCodingScheme = CALLOC(1, sizeof(OCTET_STRING_t));
+          sib8->dataCodingScheme->size = 1;
+          sib8->dataCodingScheme->buf = CALLOC(1, 1);
+          get_config_value(config_file, "dataCodingScheme", hex_str);
+          hex2bytes(hex_str, sib8->dataCodingScheme->buf, 1);
+        
+          sib8->warningMessageSegment.size = 84;
+          sib8->warningMessageSegment.buf  = CALLOC(sib8->warningMessageSegment.size, sizeof(uint8_t));
+        
+          segment =  sib8->warningMessageSegment.buf;
+          segment[i++] = num_segments;
+      } else{
+          sib8->dataCodingScheme = NULL;
+        
+          sib8->warningMessageSegment.size = 83;
+          sib8->warningMessageSegment.buf  = CALLOC(sib8->warningMessageSegment.size, sizeof(uint8_t));
+        
+          segment =  sib8->warningMessageSegment.buf;
+      }
+  
+      sib8->warningMessageSegmentNumber = seg_no;
+
+      if (seg_no == num_segments - 1) {
+        sib8->warningMessageSegmentType = NR_SIB8__warningMessageSegmentType_lastSegment;
+      } else {
+        sib8->warningMessageSegmentType = NR_SIB8__warningMessageSegmentType_notLastSegment;
+      }
+    
+      sib8->serialNumber.size = 2;
+      sib8->serialNumber.buf  = CALLOC(2, sizeof(uint8_t));
+      get_config_value(config_file, "serialNumber", hex_str);
+      hex2bytes(hex_str, sib8->serialNumber.buf, 2);
+      sib8->serialNumber.bits_unused = 0;
+
+    }else if(mode[0] == '1'){
+      
+      sib8->dataCodingScheme = CALLOC(1, sizeof(OCTET_STRING_t));
+      sib8->dataCodingScheme->size = 1;
+      sib8->dataCodingScheme->buf = CALLOC(1, 1);
+      get_config_value(config_file, "dataCodingScheme", hex_str);
+      hex2bytes(hex_str, sib8->dataCodingScheme->buf, 1);
+      
+      sib8->warningMessageSegment.size = 84;
+      sib8->warningMessageSegment.buf  = CALLOC(sib8->warningMessageSegment.size, sizeof(uint8_t));
+      
+      segment =  sib8->warningMessageSegment.buf;
+      segment[i++] = 1;
+
+      sib8->warningMessageSegmentNumber = 0;
+      sib8->warningMessageSegmentType = NR_SIB8__warningMessageSegmentType_lastSegment;
+
+      sib8->serialNumber.size = 2;
+      sib8->serialNumber.buf  = CALLOC(2, sizeof(uint8_t));
+      sib8->serialNumber.buf[0] = 0x3F;
+      sib8->serialNumber.buf[1] = seg_no;
+      sib8->serialNumber.bits_unused = 0;
+
+    }else if(mode[0] == '2'){
+      
+      if (seg_no < num_segments/2){
+
+        sib8->warningMessageSegmentType = NR_SIB8__warningMessageSegmentType_notLastSegment;
+
+        sib8->dataCodingScheme = CALLOC(1, sizeof(OCTET_STRING_t));
+        sib8->dataCodingScheme->size = 1;
+        sib8->dataCodingScheme->buf = CALLOC(1, 1);
+        get_config_value(config_file, "dataCodingScheme", hex_str);
+        hex2bytes(hex_str, sib8->dataCodingScheme->buf, 1);
+
+        sib8->warningMessageSegment.size = 84;
+        sib8->warningMessageSegment.buf  = CALLOC(sib8->warningMessageSegment.size, sizeof(uint8_t));
+
+        segment =  sib8->warningMessageSegment.buf;
+        segment[i++] = 2;
+
+        sib8->serialNumber.size = 2;
+        sib8->serialNumber.buf  = CALLOC(2, sizeof(uint8_t));
+        sib8->serialNumber.buf[0] = 0x3F;
+        sib8->serialNumber.buf[1] = seg_no;
+        sib8->serialNumber.bits_unused = 0;
+
+        sib8->warningMessageSegmentNumber = 0;
+
+      } else {
+        sib8->warningMessageSegmentType = NR_SIB8__warningMessageSegmentType_lastSegment;
+        sib8->dataCodingScheme = NULL;
+
+        sib8->warningMessageSegment.size = 83;
+        sib8->warningMessageSegment.buf  = CALLOC(sib8->warningMessageSegment.size, sizeof(uint8_t));
+
+        segment =  sib8->warningMessageSegment.buf;
+        sib8->serialNumber.size = 2;
+        sib8->serialNumber.buf  = CALLOC(2, sizeof(uint8_t));
+        sib8->serialNumber.buf[0] = 0x3F;
+        sib8->serialNumber.buf[1] = seg_no - num_segments/2;
+        sib8->serialNumber.bits_unused = 0;
+
+        sib8->warningMessageSegmentNumber = 1;
+      } 
+    }
+
+    if (*dcs == 0x01) {
+      int start = seg_no * 93;
+      gsm_7bit_encode_n(segment + i,
+                        82,
+                        alert_buffer + start,
+                        segment + 82 + i);
+    } else {
+      int start = seg_no * 82;
+      int remain = total_octets - start;
+      int this_len = remain > 82 ? 82 : remain;
+      
+
+      if (this_len > 0)
+        memcpy(segment + i, encoded + start, this_len);
+
+      segment[82 + i] = this_len;
+      
+    }
+
+        
+    sib8->messageIdentifier.size = 2;
+    sib8->messageIdentifier.buf  = CALLOC(2, sizeof(uint8_t));
+    get_config_value(config_file, "messageIdentifier", hex_str);
+    hex2bytes(hex_str, sib8->messageIdentifier.buf, 2);
+    sib8->messageIdentifier.bits_unused = 0;
+   
+    LOG_I(NR_RRC, "[SIB8] segments numer:%d and number of segments:%ld\n",seg_no,num_segments);
+
+    printf("[SIB8][HEX] ");
+    for (size_t i = 0; i < sib8->warningMessageSegment.size; i++)
+        printf("%02X ", segment[i]);
+    printf("\n");
+
+
+    // ASN.1 encode this SIB8
+    uint8_t *encoded_sib8 = NULL;
+    ssize_t enc_size = uper_encode_to_new_buffer(&asn_DEF_NR_SIB8,
+                                                 NULL,
+                                                 (void *)sib8,
+                                                 (void **)&encoded_sib8);
+    AssertFatal(enc_size > 0, "SIB8: ASN1 encoding failed (seg %d)\n", seg_no);
+
+    
+    segments[seg_no].SIB_buffer  = encoded_sib8;
+    segments[seg_no].SIB_size = enc_size;
+
+    ASN_STRUCT_FREE(asn_DEF_NR_SIB8, sib8);
+  }
+
+  free(encoded);
+
+  *out_segments    = segments;
+  *out_num_segments = num_segments;
+  return 0;
+}
 
