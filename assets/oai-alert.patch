+void nr_mac_configure_pws_si(gNB_MAC_INST *nrmac, const pws_system_information_t *pws_system_information)
+{
+  
+  NR_COMMON_channels_t *cc = &nrmac->common_channels[0];
+
+
+  int num_segments = 1 + pws_system_information->num_additional_sibs;
+
+  NR_SystemInformation_IEs_t **sysInfo_list = calloc(num_segments, sizeof(*sysInfo_list));
+  for (int i = 0; i < num_segments; i++)
+    sysInfo_list[i] = calloc(1, sizeof(*sysInfo_list[i]));
+
+
+  uint8_t *SI_container;
+  int SI_container_length;
+  for (int i = 0; i < num_segments; i++) {
+    
+    if(i == 0) {
+      SI_container = pws_system_information->sib_message.SI_container;
+      SI_container_length = pws_system_information->sib_message.SI_container_length;
+    }
+    else {
+      SI_container = pws_system_information->additional_sibs[i-1].SI_container;
+      SI_container_length = pws_system_information->additional_sibs[i-1].SI_container_length;
+    }
+    
+    struct NR_SystemInformation_IEs__sib_TypeAndInfo__Member *type = calloc(1, sizeof(*type));
+    type->present = NR_SystemInformation_IEs__sib_TypeAndInfo__Member_PR_sib8;
+    // SIB8 coming from CU need to decode it
+    NR_SIB8_t *sib8 = NULL;
+    asn_dec_rval_t dec_rval = uper_decode(NULL,
+                                          &asn_DEF_NR_SIB8,
+                                          (void **)&sib8,
+                                          SI_container,
+                                          SI_container_length,
+                                          0,
+                                          0);
+    if (dec_rval.code != RC_OK) {
+      LOG_E(NR_MAC, "cannot decode SIB8 from CU\n");
+      free(SI_container);
+    }
+    type->choice.sib8 = sib8;
+    add_sib_to_systeminformation(sysInfo_list[i], type);      
+  }
+
+  const int start = cc->other_si_used;
+  const int old_count = cc->pws_si_count;
+
+
+  update_SIB1_PWS_SI(cc->sib1, num_segments, pws_system_information->sib_type, old_count);
+  cc->sib1_bcch_length = encode_SIB_NR(cc->sib1, cc->sib1_bcch_pdu, sizeof(cc->sib1_bcch_pdu));
+  AssertFatal(cc->sib1_bcch_length > 0, "could not encode SIB1\n");
+
+
+  // generate SI messages PDU payloads
+  for (int i = 0; i < num_segments; i++) {
+    const int si_idx = start + i;
+    AssertFatal(si_idx < MAX_SI_MESSAGE, "PWS SI index %d out of range\n", si_idx);
+
+    cc->other_sib_bcch_length[si_idx] = encode_sysinfo_ie(sysInfo_list[i], 
+                                                       cc->other_sib_bcch_pdu[si_idx], 
+                                                       sizeof(cc->other_sib_bcch_pdu[si_idx]));
+
+    ASN_STRUCT_FREE(asn_DEF_NR_SystemInformation_IEs, sysInfo_list[i]);
+  }
+  free(sysInfo_list);
+  for (int i = num_segments; i < old_count; i++) {
+    const int si_idx = start + i;
+    cc->other_sib_bcch_length[si_idx] = 0;
+  }
+
+  cc->pws_si_count = num_segments;
+  
+}
