+void write_replace_warning_req_trigger(sctp_assoc_t assoc_id)
+{
+  gNB_RRC_INST *rrc = RC.nrrrc[0];
+  DevAssert(rrc);
+  if (!rrc || !rrc->mac_rrc.write_replace_warning_req) {
+    LOG_E(NR_RRC, "PWS: mac_rrc.write_replace_warning_req not initialized\n");
+    return;
+  }
+  
+  write_replace_warning_req_t wrw = {
+      .pws_system_information = {
+        .sib_type = 8,
+        .num_additional_sibs = 0,
+      },
+  };
+
+
+  pws_system_information_t *pws = &wrw.pws_system_information;
+
+  nr_SIBs_t *seg_array = NULL;
+  int nseg = 0;
+  if (build_sib8_segments(&seg_array, &nseg) < 0 || nseg <= 0) {
+    AssertFatal(false, "SIB8: cannot build segments\n");
+  }
+
+  // First segment
+  pws->sib_message.SI_container        = seg_array[0].SIB_buffer;
+  pws->sib_message.SI_container_length = seg_array[0].SIB_size;
+
+  // Remaining segments (if any)
+  int add = nseg - 1;
+  if (add > PWS_MAX_NO_Additional_SIBs)
+    add = PWS_MAX_NO_Additional_SIBs;
+
+  pws->num_additional_sibs = add;
+
+  for (int i = 0; i < add; i++) {
+    pws->additional_sibs[i].SI_container        = seg_array[i + 1].SIB_buffer;
+    pws->additional_sibs[i].SI_container_length = seg_array[i + 1].SIB_size;
+  }
+    
+  rrc->mac_rrc.write_replace_warning_req(assoc_id, &wrw);
+
+  for (int i = 0; i < nseg; i++) {
+    free(seg_array[i].SIB_buffer);
+  }
+  free(seg_array);
+}
