+int gsm_7bit_encode_n(uint8_t *result, size_t n, const char *data, uint8_t *octets)
+{
+  int y = 0;
+  size_t o;
+  size_t max_septets = n * 8 / 7;
+
+  /* prepare for the worst case, every character expanding to two bytes */
+  uint8_t *rdata = malloc(strlen(data) * 2);
+  y = gsm_septet_encode(rdata, data);
+
+  if (y > max_septets) {
+    /*
+     * Limit the number of septets to avoid the generation
+     * of more than n octets.
+     */
+    y = max_septets;
+  }
+
+  o = gsm_septet_pack(result, rdata, y, 0);
+
+  if (octets)
+    *octets = o;
+
+  free(rdata);
+
+  /*
+   * We don't care about the number of octets, because they are not
+   * unique. E.g.:
+   *  1.) 46 non-extension characters + 1 extension character
+   *         => (46 * 7 bit + (1 * (2 * 7 bit))) / 8 bit =  42 octets
+   *  2.) 47 non-extension characters
+   *         => (47 * 7 bit) / 8 bit = 41,125 = 42 octets
+   *  3.) 48 non-extension characters
+   *         => (48 * 7 bit) / 8 bit = 42 octects
+   */
+  return y;
+}
+
+size_t utf8_to_ucs2(const char *utf8, uint8_t *ucs2, size_t max_bytes)
+{
+  if (!ucs2)
+    return 0;
+  const unsigned char *p = (const unsigned char *)utf8;
+  size_t i = 0;
+
+  while (*p) {
+    uint32_t codepoint = 0;
+
+    if (*p < 0x80) {
+      codepoint = *p++;
+    } else if ((*p & 0xE0) == 0xC0) {
+      codepoint = (*p++ & 0x1F) << 6;
+      codepoint |= (*p++ & 0x3F);
+    } else if ((*p & 0xF0) == 0xE0) {
+      codepoint = (*p++ & 0x0F) << 12;
+      codepoint |= (*p++ & 0x3F) << 6;
+      codepoint |= (*p++ & 0x3F);
+    } else {
+      // Skip 4-byte (U+10000+), not valid in UCS-2
+      p += 4;
+      continue;
+    }
+
+    if (codepoint > 0xFFFF)
+      continue; // Out of UCS-2 range
+
+    ucs2[i++] = (uint8_t)(codepoint >> 8);
+    ucs2[i++] = (uint8_t)codepoint;
+    if(i >= max_bytes - 1) {
+      // Prevent overflow, UCS-2 buffer should not exceed max bytes
+      return i;
+    }
+  }
+
+  return i;
+}
